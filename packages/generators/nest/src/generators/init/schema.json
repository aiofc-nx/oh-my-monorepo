{
  "$schema": "https://json-schema.org/schema",
  "$id": "OksaiNestInitGenerator",
  "title": "Init Generator",
  "description": "Initialize NestJS dependencies",
  "cli": "nx",
  "type": "object",
  "properties": {
    "skipFormat": {
      "type": "boolean",
      "description": "Skip formatting files",
      "default": false,
      "x-priority": "internal"
    },
    "skipPackageJson": {
      "type": "boolean",
      "description": "Do not add dependencies to package.json",
      "default": false,
      "x-priority": "internal"
    }
  },
  "additionalProperties": false
}

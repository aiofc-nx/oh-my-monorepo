{
  "$schema": "https://json-schema.org/schema",
  "$id": "OksaiReactStorybookConfigurationGenerator",
  "title": "Storybook Configuration Generator",
  "description": "Add Storybook to a React project.",
  "cli": "nx",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "The name of the project.",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "Which project would you like to add Storybook to?"
    },
    "skipFormat": {
      "type": "boolean",
      "description": "Skip formatting.",
      "default": false
    },
    "skipPackageJson": {
      "type": "boolean",
      "description": "Skip adding dependencies.",
      "default": false
    }
  },
  "required": ["project"],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/schema",
  "$id": "OksaiReactApplicationGenerator",
  "title": "React Application Generator",
  "description": "Create a React application with Vite.",
  "cli": "nx",
  "type": "object",
  "properties": {
    "directory": {
      "type": "string",
      "description": "The directory of the new application",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "Which directory do you want to create the application in?",
      "x-priority": "important"
    },
    "name": {
      "type": "string",
      "description": "The name of the application",
      "x-priority": "important"
    },
    "style": {
      "type": "string",
      "description": "The file extension to be used for style files.",
      "default": "css",
      "enum": ["css", "scss", "less", "none"],
      "x-prompt": "Which stylesheet format would you like to use?",
      "x-priority": "important"
    },
    "routing": {
      "type": "boolean",
      "description": "Generate routing configuration.",
      "default": false
    },
    "unitTestRunner": {
      "type": "string",
      "description": "Test runner to use for unit tests.",
      "enum": ["vitest", "none"],
      "default": "vitest",
      "x-priority": "important"
    },
    "e2eTestRunner": {
      "type": "string",
      "description": "Test runner to use for e2e tests.",
      "enum": ["playwright", "none"],
      "default": "playwright",
      "x-priority": "important"
    },
    "tags": {
      "type": "string",
      "description": "Add tags to the application (used for linting).",
      "alias": "t"
    },
    "strict": {
      "type": "boolean",
      "description": "Whether to enable strict type checking.",
      "default": true
    },
    "skipFormat": {
      "type": "boolean",
      "description": "Skip formatting files.",
      "default": false,
      "x-priority": "internal"
    },
    "skipPackageJson": {
      "type": "boolean",
      "description": "Do not add dependencies to package.json.",
      "default": false,
      "x-priority": "internal"
    },
    "rootProject": {
      "type": "boolean",
      "description": "Create a root level application.",
      "default": false,
      "x-priority": "internal"
    }
  },
  "required": ["directory"],
  "additionalProperties": false
}

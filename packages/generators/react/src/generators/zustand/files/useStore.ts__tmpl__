import { create } from 'zustand';

interface <%= className %>State {
  count: number;
  increment: () => void;
  decrement: () => void;
  reset: () => void;
}

export const use<%= className %>Store = create<<%= className %>State>((set) => ({
  count: 0,
  increment: () => set((state) => ({ count: state.count + 1 })),
  decrement: () => set((state) => ({ count: state.count - 1 })),
  reset: () => set({ count: 0 }),
}));

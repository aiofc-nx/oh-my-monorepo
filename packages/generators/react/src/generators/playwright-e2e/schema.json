{
  "$schema": "https://json-schema.org/schema",
  "$id": "OksaiReactPlaywrightE2EGenerator",
  "title": "Playwright E2E Generator",
  "description": "Add Playwright E2E testing to a React project.",
  "cli": "nx",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "The name of the project.",
      "alias": "p",
      "$default": {
        "$source": "projectName"
      },
      "x-prompt": "Which project would you like to add E2E tests to?"
    },
    "skipFormat": {
      "type": "boolean",
      "description": "Skip formatting.",
      "default": false
    },
    "skipPackageJson": {
      "type": "boolean",
      "description": "Skip adding dependencies.",
      "default": false
    }
  },
  "required": ["project"],
  "additionalProperties": false
}

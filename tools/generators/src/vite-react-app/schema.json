{
  "$schema": "http://json-schema.org/schema",
  "$id": "ViteReactApp",
  "title": "Create React Application (Vite + TypeScript)",
  "description": "创建 React 应用，使用 Vite + TypeScript + Tailwind（可选）",
  "type": "object",
  "examples": [
    {
      "command": "nx g vite-react-app myapp",
      "description": "在 apps/myapp 创建 React 应用"
    },
    {
      "command": "nx g vite-react-app myapp --style=tailwind",
      "description": "创建带 Tailwind CSS 的 React 应用"
    },
    {
      "command": "nx g vite-react-app myapp --routing",
      "description": "创建带路由的 React 应用"
    }
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "应用名称",
      "pattern": "(?:^@[a-zA-Z0-9-*~][a-zA-Z0-9-*._~]*\\/[a-zA-Z0-9-~][a-zA-Z0-9-._~]*|^[a-zA-Z][^:]*)$",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "应用名称?"
    },
    "directory": {
      "type": "string",
      "description": "应用目录 (默认: apps/<name>)",
      "alias": "dir"
    },
    "tags": {
      "type": "string",
      "description": "项目标签 (逗号分隔)",
      "default": "type:app,framework:react,bundler:vite",
      "alias": "t"
    },
    "style": {
      "type": "string",
      "description": "样式方案",
      "enum": ["css", "tailwind", "none"],
      "default": "css",
      "x-prompt": {
        "message": "选择样式方案?",
        "type": "list",
        "items": [
          { "value": "css", "label": "CSS" },
          { "value": "tailwind", "label": "Tailwind CSS" },
          { "value": "none", "label": "无样式" }
        ]
      }
    },
    "routing": {
      "type": "boolean",
      "description": "添加 React Router",
      "default": false,
      "x-prompt": "是否添加路由?"
    },
    "inSourceTests": {
      "type": "boolean",
      "description": "在源码中编写测试",
      "default": false
    },
    "skipPackageJson": {
      "type": "boolean",
      "description": "跳过添加依赖到 package.json",
      "default": false,
      "x-priority": "internal"
    },
    "skipFormat": {
      "type": "boolean",
      "description": "跳过格式化",
      "default": false,
      "x-priority": "internal"
    }
  },
  "required": ["name"]
}

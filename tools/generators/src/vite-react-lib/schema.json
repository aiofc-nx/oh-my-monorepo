{
  "$schema": "http://json-schema.org/schema",
  "$id": "ViteReactLib",
  "title": "Create React Library (Vite + TypeScript)",
  "description": "创建 React 库，使用 Vite + TypeScript + Tailwind（可选）",
  "type": "object",
  "examples": [
    {
      "command": "nx g vite-react-lib mylib",
      "description": "在 libs/mylib 创建 React 库"
    },
    {
      "command": "nx g vite-react-lib mylib --buildable",
      "description": "创建可构建的 React 库"
    },
    {
      "command": "nx g vite-react-lib mylib --publishable --importPath=@myorg/mylib",
      "description": "创建可发布的 React 库"
    }
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "库名称",
      "pattern": "(?:^@[a-zA-Z0-9-*~][a-zA-Z0-9-*._~]*\\/[a-zA-Z0-9-~][a-zA-Z0-9-._~]*|^[a-zA-Z][^:]*)$",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "库名称?"
    },
    "directory": {
      "type": "string",
      "description": "库目录 (默认: libs/<name>)",
      "alias": "dir"
    },
    "tags": {
      "type": "string",
      "description": "项目标签 (逗号分隔)",
      "default": "type:lib,framework:react,bundler:vite",
      "alias": "t"
    },
    "style": {
      "type": "string",
      "description": "样式方案",
      "enum": ["css", "tailwind", "none"],
      "default": "css",
      "x-prompt": {
        "message": "选择样式方案?",
        "type": "list",
        "items": [
          { "value": "css", "label": "CSS" },
          { "value": "tailwind", "label": "Tailwind CSS" },
          { "value": "none", "label": "无样式" }
        ]
      }
    },
    "buildable": {
      "type": "boolean",
      "description": "创建可构建的库",
      "default": false,
      "x-prompt": "是否可构建?"
    },
    "publishable": {
      "type": "boolean",
      "description": "创建可发布的库",
      "default": false
    },
    "importPath": {
      "type": "string",
      "description": "导入路径 (例如: @myorg/mylib)"
    },
    "skipPackageJson": {
      "type": "boolean",
      "description": "跳过添加依赖到 package.json",
      "default": false,
      "x-priority": "internal"
    },
    "skipFormat": {
      "type": "boolean",
      "description": "跳过格式化",
      "default": false,
      "x-priority": "internal"
    }
  },
  "required": ["name"]
}

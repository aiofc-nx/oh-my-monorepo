{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "oksai.cc NestJS Application",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "sourceMap": true,
    "incremental": true,
    "noEmit": false,
    "types": ["node", "@nestjs/core"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.e2e.ts"]
}

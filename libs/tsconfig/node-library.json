{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "oksai.cc Node.js Library (ESM)",
  "extends": "./base.json",
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "sourceMap": true,
    "noEmit": false,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}

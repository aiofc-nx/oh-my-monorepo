{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "libs/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/*.d.ts",
    "**/*.spec.ts",
    "**/*.test.ts"
  ],
  "ignoreDependencies": ["@types/node", "typescript", "tslib"]
}
